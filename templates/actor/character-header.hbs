{{!-- character-header.hbs — Invincible-style header --}}
<div class="main-sheet">
  <header class="sheet-header">
    <img src="systems/paragons/assets/paragons-logo.webp" class="sheet-logo"
         onerror="this.style.display='none'" />
    <div class="bg-accent"></div>

    {{!-- Portrait --}}
    <div class="header-portrait">
      <img class="profile-img clickable"
           src="{{actor.img}}"
           data-action="onEditImage"
           data-tooltip="Change portrait" />
    </div>

    {{!-- Identity --}}
    <div class="header-fields">
      <div class="header-name-row">
        <div class="form-group name-wide">
          <label>Paragon Name</label>
          <input type="text" name="name" value="{{actor.name}}" placeholder="Name" />
        </div>
        <div class="form-group">
          <label>Secret Identity</label>
          <input type="text" name="system.secretId" value="{{system.secretId}}" placeholder="Civilian name" />
        </div>
      </div>
      <div class="header-meta-row">
        <div class="form-group">
          <label>Pronouns</label>
          <input type="text" name="system.pronouns" value="{{system.pronouns}}" placeholder="they/them" />
        </div>
        <div class="form-group">
          <label>Player</label>
          <input type="text" name="system.playerName" value="{{system.playerName}}" />
        </div>
        <div class="form-group level-group">
          <label>Level</label>
          <input type="number" name="system.level" value="{{system.level}}" min="1" max="20" />
        </div>
        <div class="form-group">
          <label>Archetype</label>
          <select name="system.archetype">
            <option value="">— Choose —</option>
            {{#each archetypeChoices}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </div>
      </div>
      <div class="header-notes-row">
        <div class="form-group notes-wide">
          <label>Session Notes</label>
          <input type="text" name="system.sessionNotes" value="{{system.sessionNotes}}" placeholder="Notes for this session..." />
        </div>
      </div>
    </div>
  </header>
</div>
