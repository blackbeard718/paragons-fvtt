<section class="tab {{tabs.primary.play.cssClass}}" data-tab="play" data-group="primary">

  {{!-- STATS --}}
  <div class="stats-row">
    {{#each stats}}
    <div class="stat-block" data-action="rollStat" data-stat="{{key}}">
      <div class="stat-label">{{label}}</div>
      <div class="stat-value-wrap">
        <input type="number" name="system.stats.{{key}}" value="{{value}}" min="1" max="10" class="stat-value" />
      </div>
      <div class="stat-icon" data-stat-icon="{{key}}"></div>
    </div>
    {{/each}}
  </div>

  {{!-- DERIVED --}}
  <div class="derived-row">
    <div class="derived-block will-block">
      <div class="derived-label">Will</div>
      <div class="derived-values">
        <input type="number" name="system.will.value" value="{{system.will.value}}" min="0" class="derived-current" />
        <span class="derived-sep">/</span>
        <span class="derived-max">{{system.will.max}}</span>
      </div>
      <div class="derived-sublabel">Level + Stamina</div>
    </div>
    <div class="derived-block resist-block">
      <div class="derived-label">Resist</div>
      <div class="derived-values">
        <input type="number" name="system.resist.value" value="{{system.resist.value}}" min="0" class="derived-current" />
        <span class="derived-sep">/</span>
        <span class="derived-max">{{system.resist.max}}</span>
      </div>
      <div class="derived-sublabel">Physique + Acuity</div>
    </div>
    <div class="derived-block movement-block">
      <div class="derived-label">Movement</div>
      <div class="derived-values">
        <input type="number" name="system.movement" value="{{system.movement}}" min="0" class="derived-current single" />
      </div>
      <div class="derived-sublabel">hexes (base 8)</div>
    </div>
    <div class="derived-block coolpoints-block">
      <div class="derived-label">Cool Points</div>
      <div class="derived-values">
        <input type="number" name="system.coolPoints.value" value="{{system.coolPoints.value}}" min="0" class="derived-current" />
        <span class="derived-sep">/</span>
        <span class="derived-max">{{system.coolPoints.max}}</span>
      </div>
      <div class="derived-sublabel">Level + Presence</div>
    </div>
  </div>

  {{!-- TALENTS + GEAR --}}
  <div class="talents-gear-row">

    <div class="talents-section">
      <div class="section-header">
        <span class="section-title">Talents</span>
        <button type="button" data-action="itemCreate" data-type="talent" class="item-create-btn">+</button>
      </div>
      <div class="item-list talents-list">
        {{#each talents}}
        <div class="item-row talent-row" data-item-id="{{id}}">
          <div class="item-name">
            <span class="talent-archetype-pip" data-archetype="{{system.archetype}}"></span>
            <span class="item-label">{{name}}</span>
            {{#if system.hasUses}}<span class="uses-pip">{{system.uses.current}}/{{system.uses.max}}</span>{{/if}}
          </div>
          <div class="item-controls">
            <button type="button" data-action="itemEdit"   data-item-id="{{id}}" title="Edit">✎</button>
            <button type="button" data-action="itemDelete" data-item-id="{{id}}" title="Delete">✕</button>
          </div>
        </div>
        {{else}}
        <div class="item-row empty-row"><span class="empty-label">No talents yet</span></div>
        {{/each}}
      </div>
    </div>

    <div class="gear-section">
      <div class="section-header">
        <span class="section-title">Gear</span>
        <button type="button" data-action="itemCreate" data-type="gear" class="item-create-btn">+</button>
      </div>
      <div class="item-list gear-list">
        {{#each gear}}
        <div class="item-row gear-row {{#unless system.equipped}}unequipped{{/unless}}" data-item-id="{{id}}">
          <div class="item-name">
            <span class="gear-dice-badge">{{system.gearDice}}d6</span>
            <span class="item-label">{{name}}</span>
            {{#if system.isDefensive}}<span class="defensive-badge" title="Defensive">🛡</span>{{/if}}
          </div>
          <div class="item-controls">
            <button type="button" data-action="itemEquipToggle" data-item-id="{{id}}"
                    title="{{#if system.equipped}}Unequip{{else}}Equip{{/if}}">
              {{#if system.equipped}}◉{{else}}◎{{/if}}
            </button>
            <button type="button" data-action="itemEdit"   data-item-id="{{id}}" title="Edit">✎</button>
            <button type="button" data-action="itemDelete" data-item-id="{{id}}" title="Delete">✕</button>
          </div>
        </div>
        {{else}}
        <div class="item-row empty-row"><span class="empty-label">No gear</span></div>
        {{/each}}
      </div>
    </div>

  </div>

  {{!-- ABILITIES --}}
  <div class="abilities-section">
    <div class="section-header">
      <span class="section-title">Abilities</span>
      <button type="button" data-action="itemCreate" data-type="ability" class="item-create-btn">+</button>
    </div>
    <div class="item-list abilities-list">
      {{#each abilities}}
      <div class="item-row ability-row" data-item-id="{{id}}">
        <div class="item-name">
          <span class="ability-level-badge">L{{system.abilityLevel}}</span>
          <span class="item-label">{{name}}</span>
          {{#if system.prerequisite}}<span class="prereq-badge">Req: {{system.prerequisite}}</span>{{/if}}
          {{#if system.hasUses}}
          <span class="uses-pip">
            {{system.uses.current}}/{{system.uses.max}}
            <button type="button" data-action="useAbility" data-item-id="{{id}}">▶</button>
          </span>
          {{/if}}
        </div>
        {{#if system.diceBonus.amount}}
        <div class="item-summary">+{{system.diceBonus.amount}}d6 {{system.diceBonus.condition}}</div>
        {{/if}}
        <div class="item-controls">
          <button type="button" data-action="itemEdit"   data-item-id="{{id}}" title="Edit">✎</button>
          <button type="button" data-action="itemDelete" data-item-id="{{id}}" title="Delete">✕</button>
        </div>
      </div>
      {{else}}
      <div class="item-row empty-row"><span class="empty-label">No abilities yet</span></div>
      {{/each}}
    </div>
  </div>

  {{!-- REPUTATION --}}
  <div class="reputation-section">
    <div class="section-title">Reputation</div>
    <div class="reputation-track">
      {{#each reputationTiers}}
      <div class="rep-tier {{#if active}}active{{/if}} {{#if current}}current{{/if}}"
           data-action="repTierSet" data-tier="{{index}}">
        <span class="rep-label">{{label}}</span>
      </div>
      {{/each}}
    </div>
    <div class="reputation-counters">
      <label>Feats:
        <input type="number" name="system.reputation.featsEarned" value="{{system.reputation.featsEarned}}" min="0" />
      </label>
      {{#if reputationThreshold.featsNeeded}}
      <span class="rep-threshold">/ {{reputationThreshold.featsNeeded}} to advance</span>
      {{/if}}
      <label>Failures:
        <input type="number" name="system.reputation.failuresEarned" value="{{system.reputation.failuresEarned}}" min="0" />
      </label>
      {{#if reputationThreshold.failuresNeeded}}
      <span class="rep-threshold">/ {{reputationThreshold.failuresNeeded}} to drop</span>
      {{/if}}
    </div>
  </div>

</section>
