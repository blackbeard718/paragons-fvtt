<section class="tab {{tabs.play.cssClass}}" data-tab="play" data-group="primary">

  {{!-- STATS — attribute grid --}}
  <label class="title attribute">Stats</label>
  <div class="grid grid-5col stats-grid">
    {{#each stats}}
    <div class="attribute {{key}}" data-action="rollStat" data-stat="{{key}}">
      <img class="stat-icon" src="systems/paragons/icons/{{key}}.svg" alt="{{label}}" />
      <input type="number" name="system.stats.{{key}}" value="{{value}}" min="1" max="10"
             data-dtype="Number" />
      <label class="attribute-label rollable" data-action="rollStat" data-stat="{{key}}">
        {{label}}
      </label>
    </div>
    {{/each}}
  </div>

  {{!-- DERIVED — Will / Resist / Movement / Cool Points --}}
  <div class="derived-row">
    <div class="bar">
      <img class="derived-icon" src="systems/paragons/icons/will.svg" alt="Will" />
      <label>Will</label>
      <div class="bar-track">{{bar system.will.value system.will.max}}</div>
      <div class="form-fields">
        <input type="number" name="system.will.value" value="{{system.will.value}}" min="0" data-dtype="Number" />
        <label>/</label>
        <label>{{system.will.max}}</label>
      </div>
      <label class="derived-sublabel">Level + Stamina</label>
    </div>
    <div class="bar">
      <img class="derived-icon" src="systems/paragons/icons/resist.svg" alt="Resist" />
      <label>Resist</label>
      <div class="bar-track">{{bar system.resist.value system.resist.max}}</div>
      <div class="form-fields">
        <input type="number" name="system.resist.value" value="{{system.resist.value}}" min="0" data-dtype="Number" />
        <label>/</label>
        <label>{{system.resist.max}}</label>
      </div>
      <label class="derived-sublabel">Physique + Acuity</label>
    </div>
    <div class="bar bar-single">
      <img class="derived-icon" src="systems/paragons/icons/movement.svg" alt="Movement" />
      <label>Movement</label>
      <div class="form-fields">
        <input type="number" name="system.movement" value="{{system.movement}}" min="0" data-dtype="Number" class="derived-single" />
        <label class="derived-sublabel">hexes</label>
      </div>
    </div>
    <div class="bar bar-coolpoints">
      <img class="derived-icon" src="systems/paragons/icons/cool-points.svg" alt="Cool Points" />
      <label>Cool Points</label>
      <div class="bar-track">{{bar system.coolPoints.value system.coolPoints.max}}</div>
      <div class="form-fields">
        <input type="number" name="system.coolPoints.value" value="{{system.coolPoints.value}}" min="0" data-dtype="Number" />
        <label>/</label>
        <label>{{system.coolPoints.max}}</label>
      </div>
      <label class="derived-sublabel">Level + Presence</label>
    </div>
  </div>

  {{!-- TALENTS --}}
  <label class="title">
    <img class="section-icon" src="systems/paragons/icons/talents.svg" alt="" />
    Talents
    {{#if @root.editable}}
    <button type="button" class="item-create title-btn" data-action="itemCreate" data-type="talent">
      <i class="fas fa-plus"></i>
    </button>
    {{/if}}
  </label>
  <ul class="items-list">
    <li class="item flexrow items-header">
      <div class="item-name">Name</div>
      <div class="item-meta">Archetype</div>
      <div class="item-controls"></div>
    </li>
    {{#each talents}}
    <li class="item talent-info flexrow draggable" data-item-id="{{id}}" data-document-class="Item">
      <div class="item-name">
        <div class="item-image">
          <img src="{{img}}" width="24" height="24" data-tooltip="{{name}}" />
        </div>
        <span>{{name}}</span>
        {{#if system.hasUses}}<span class="uses-badge">{{system.uses.current}}/{{system.uses.max}}</span>{{/if}}
      </div>
      <div class="item-meta talent-archetype">{{system.archetype}}</div>
      <div class="item-controls">
        <a class="item-control" data-action="viewDoc" data-item-id="{{id}}" data-tooltip="Edit">
          <i class="fas fa-edit"></i>
        </a>
        {{#if @root.editable}}
        <a class="item-control" data-action="itemDelete" data-item-id="{{id}}" data-tooltip="Delete">
          <i class="fas fa-trash"></i>
        </a>
        {{/if}}
      </div>
    </li>
    {{else}}
    <li class="item flexrow empty-row"><span class="empty-label">No talents yet</span></li>
    {{/each}}
  </ul>

  {{!-- GEAR --}}
  <label class="title">
    <img class="section-icon" src="systems/paragons/icons/gear.svg" alt="" />
    Gear
    {{#if @root.editable}}
    <button type="button" class="item-create title-btn" data-action="itemCreate" data-type="gear">
      <i class="fas fa-plus"></i>
    </button>
    {{/if}}
  </label>
  <ul class="items-list">
    <li class="item flexrow items-header">
      <div class="item-name">Name</div>
      <div class="item-meta">Dice</div>
      <div class="item-meta">Range</div>
      <div class="item-controls"></div>
    </li>
    {{#each gear}}
    <li class="item gear-info flexrow draggable {{#unless system.equipped}}unequipped{{/unless}}"
        data-item-id="{{id}}" data-document-class="Item">
      <div class="item-name">
        <div class="item-image">
          <img src="{{img}}" width="24" height="24" data-tooltip="{{name}}" />
        </div>
        <span>{{name}}</span>
        {{#if system.isDefensive}}<span class="defensive-badge" data-tooltip="Defensive"><i class="fas fa-shield-halved"></i></span>{{/if}}
      </div>
      <div class="item-meta">{{system.gearDice}}d6</div>
      <div class="item-meta">{{system.range}}</div>
      <div class="item-controls">
        <a class="item-control {{#if system.equipped}}equipped{{/if}}"
           data-action="itemEquipToggle" data-item-id="{{id}}"
           data-tooltip="{{#if system.equipped}}Unequip{{else}}Equip{{/if}}">
          <i class="fas {{#if system.equipped}}fa-circle-check{{else}}fa-circle{{/if}}"></i>
        </a>
        <a class="item-control" data-action="viewDoc" data-item-id="{{id}}" data-tooltip="Edit">
          <i class="fas fa-edit"></i>
        </a>
        {{#if @root.editable}}
        <a class="item-control" data-action="itemDelete" data-item-id="{{id}}" data-tooltip="Delete">
          <i class="fas fa-trash"></i>
        </a>
        {{/if}}
      </div>
    </li>
    {{else}}
    <li class="item flexrow empty-row"><span class="empty-label">No gear</span></li>
    {{/each}}
  </ul>

  {{!-- ABILITIES --}}
  <label class="title">
    <img class="section-icon" src="systems/paragons/icons/abilities.svg" alt="" />
    Abilities
    {{#if @root.editable}}
    <button type="button" class="item-create title-btn" data-action="itemCreate" data-type="ability">
      <i class="fas fa-plus"></i>
    </button>
    {{/if}}
  </label>
  <ul class="items-list abilities-list">
    <li class="item flexrow items-header">
      <div class="item-name">Name</div>
      <div class="item-meta">Level</div>
      <div class="item-controls"></div>
    </li>
    {{#each abilities}}
    <li class="item ability-info flexrow draggable" data-item-id="{{id}}" data-document-class="Item">
      <div class="item-name">
        <div class="item-image">
          <img src="{{img}}" width="24" height="24" data-tooltip="{{name}}" />
        </div>
        <span>{{name}}</span>
        {{#if system.prerequisite}}<span class="prereq-badge" data-tooltip="Requires: {{system.prerequisite}}"><i class="fas fa-lock"></i></span>{{/if}}
        {{#if system.hasUses}}<span class="uses-badge">{{system.uses.current}}/{{system.uses.max}}</span>{{/if}}
      </div>
      <div class="item-meta">L{{system.abilityLevel}}</div>
      <div class="item-controls">
        {{#if system.hasUses}}
        <a class="item-control rollable" data-action="useAbility" data-item-id="{{id}}" data-tooltip="Use ability">
          <i class="fas fa-play"></i>
        </a>
        {{/if}}
        <a class="item-control" data-action="viewDoc" data-item-id="{{id}}" data-tooltip="Edit">
          <i class="fas fa-edit"></i>
        </a>
        {{#if @root.editable}}
        <a class="item-control" data-action="itemDelete" data-item-id="{{id}}" data-tooltip="Delete">
          <i class="fas fa-trash"></i>
        </a>
        {{/if}}
      </div>
    </li>
    {{else}}
    <li class="item flexrow empty-row"><span class="empty-label">No abilities yet</span></li>
    {{/each}}
  </ul>

  {{!-- REPUTATION --}}
  <label class="title">
    <img class="section-icon" src="systems/paragons/icons/reputation.svg" alt="" />
    Reputation
  </label>
  <div class="reputation-section">
    <div class="reputation-track">
      {{#each reputationTiers}}
      <div class="rep-tier {{#if active}}active{{/if}} {{#if current}}current{{/if}}"
           data-action="repTierSet" data-tier="{{index}}">
        <span class="rep-label">{{label}}</span>
      </div>
      {{/each}}
    </div>
    <div class="reputation-counters">
      <label>Feats:
        <input type="number" name="system.reputation.featsEarned" value="{{system.reputation.featsEarned}}" min="0" />
      </label>
      {{#if reputationThreshold.featsNeeded}}
      <span class="rep-threshold">/ {{reputationThreshold.featsNeeded}} to advance</span>
      {{/if}}
      <label>Failures:
        <input type="number" name="system.reputation.failuresEarned" value="{{system.reputation.failuresEarned}}" min="0" />
      </label>
      {{#if reputationThreshold.failuresNeeded}}
      <span class="rep-threshold">/ {{reputationThreshold.failuresNeeded}} to drop</span>
      {{/if}}
    </div>
  </div>

</section>
