{{!-- templates/actor/character-sheet.hbs --}}
{{!-- Paragons Character Sheet — matches print layout --}}

<form class="paragons-sheet character-sheet" autocomplete="off">

  {{!-- ═══════════════════════════════════════════ --}}
  {{!-- SHEET TABS                                   --}}
  {{!-- ═══════════════════════════════════════════ --}}
  <nav class="sheet-tabs">
    <a class="tab-btn {{#if (eq activeTab "play")}}active{{/if}}"
       data-tab="play">Play Sheet</a>
    <a class="tab-btn {{#if (eq activeTab "concept")}}active{{/if}}"
       data-tab="concept">Concept &amp; Moves</a>
  </nav>

  {{!-- ═══════════════════════════════════════════ --}}
  {{!-- TAB: PLAY SHEET (Page 1)                    --}}
  {{!-- ═══════════════════════════════════════════ --}}
  <section class="tab-content {{#if (eq activeTab "play")}}active{{/if}}"
           data-tab="play">

    {{!-- Blue left sidebar accent --}}
    <div class="sidebar-accent"></div>

    {{!-- ── HEADER ROW ────────────────────────────── --}}
    <div class="sheet-header">
      <div class="header-main">
        <div class="field-group name-group">
          <label class="field-label">Paragon Name</label>
          <input type="text" name="name" value="{{actor.name}}"
                 class="paragon-name-input" placeholder="Paragon Name" />
        </div>
        <div class="field-group alias-group">
          <label class="field-label">Character Alias</label>
          <input type="text" name="system.secretId"
                 value="{{system.secretId}}" placeholder="Secret Identity" />
        </div>
        <div class="field-group pronouns-group">
          <label class="field-label">Pronouns</label>
          <input type="text" name="system.pronouns"
                 value="{{system.pronouns}}" placeholder="They/Them" />
        </div>
        <div class="field-group player-group">
          <label class="field-label">Player Name</label>
          <input type="text" name="system.playerName"
                 value="{{system.playerName}}" placeholder="Player" />
        </div>
      </div>

      <div class="header-sub">
        <div class="field-group level-group">
          <label class="field-label">Level</label>
          <input type="number" name="system.level"
                 value="{{system.level}}" min="1" max="20" />
        </div>
        <div class="field-group archetype-group">
          <label class="field-label">Archetype</label>
          <select name="system.archetype">
            <option value="">— Choose —</option>
            {{#each archetypeChoices}}
              <option value="{{value}}"
                {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </div>
        <div class="lightning-graphic">
          <img src="systems/paragons/assets/lightning.svg" alt="" />
        </div>
        <div class="field-group notes-group">
          <label class="field-label">Notes:</label>
          <input type="text" name="system.sessionNotes"
                 value="{{system.sessionNotes}}" placeholder="Session notes..." />
        </div>
      </div>
    </div>{{!-- /.sheet-header --}}

    {{!-- ── STATS ROW ─────────────────────────────── --}}
    <div class="stats-row">
      {{#each stats}}
      <div class="stat-block" data-stat="{{key}}">
        <div class="stat-label">{{label}}</div>
        <div class="stat-value-wrap">
          <input type="number" name="system.stats.{{key}}"
                 value="{{value}}" min="1" max="10"
                 class="stat-value" />
        </div>
        <div class="stat-icon">
          <img src="systems/paragons/assets/stat-{{key}}.svg" alt="{{label}}" />
        </div>
        <button type="button" class="stat-roll-btn invisible-btn"
                data-stat="{{key}}" title="Roll {{label}}">
        </button>
      </div>
      {{/each}}
    </div>{{!-- /.stats-row --}}

    {{!-- ── DERIVED SCORES ROW ───────────────────── --}}
    <div class="derived-row">

      <div class="derived-block will-block">
        <div class="derived-label">Will</div>
        <div class="derived-values">
          <input type="number" name="system.will.value"
                 value="{{system.will.value}}" min="0"
                 class="derived-current" />
          <span class="derived-sep">/</span>
          <span class="derived-max">{{system.will.max}}</span>
        </div>
        <div class="derived-sublabel">Level + Stamina</div>
      </div>

      <div class="derived-block resist-block">
        <div class="derived-label">Resist</div>
        <div class="derived-values">
          <input type="number" name="system.resist.value"
                 value="{{system.resist.value}}" min="0"
                 class="derived-current" />
          <span class="derived-sep">/</span>
          <span class="derived-max">{{system.resist.max}}</span>
        </div>
        <div class="derived-sublabel">Physique + Acuity</div>
      </div>

      <div class="derived-block movement-block">
        <div class="derived-label">Movement</div>
        <div class="derived-values">
          <input type="number" name="system.movement"
                 value="{{system.movement}}" min="0"
                 class="derived-current single" />
        </div>
        <div class="derived-sublabel">hexes (base 8)</div>
      </div>

      <div class="derived-block coolpoints-block">
        <div class="derived-label">Cool Points</div>
        <div class="derived-values">
          <input type="number" name="system.coolPoints.value"
                 value="{{system.coolPoints.value}}" min="0"
                 class="derived-current" />
          <span class="derived-sep">/</span>
          <span class="derived-max">{{system.coolPoints.max}}</span>
        </div>
        <div class="derived-sublabel">Level + Presence</div>
      </div>

    </div>{{!-- /.derived-row --}}

    {{!-- ── TALENTS + GEAR ROW ────────────────────── --}}
    <div class="talents-gear-row">

      {{!-- TALENTS (left ~60%) --}}
      <div class="talents-section">
        <div class="section-header">
          <span class="section-title">Talents</span>
          <button type="button" class="item-create-btn"
                  data-type="talent" title="Add Talent">+</button>
        </div>
        <div class="item-list talents-list">
          {{#each talents}}
          <div class="item-row talent-row" data-item-id="{{id}}">
            <div class="item-name">
              <span class="talent-archetype-pip" data-archetype="{{system.archetype}}"></span>
              <span class="item-label">{{name}}</span>
              {{#if system.hasUses}}
                <span class="uses-pip">
                  {{system.uses.current}}/{{system.uses.max}}
                </span>
              {{/if}}
            </div>
            <div class="item-controls">
              <button type="button" class="item-edit" data-item-id="{{id}}"
                      title="Edit">✎</button>
              <button type="button" class="item-delete" data-item-id="{{id}}"
                      title="Delete">✕</button>
            </div>
          </div>
          {{else}}
          <div class="item-row empty-row">
            <span class="empty-label">No talents yet — drag from compendium or click +</span>
          </div>
          {{/each}}
        </div>
      </div>{{!-- /.talents-section --}}

      {{!-- GEAR (right ~35%) --}}
      <div class="gear-section">
        <div class="section-header">
          <span class="section-title">Gear</span>
          <button type="button" class="item-create-btn"
                  data-type="gear" title="Add Gear">+</button>
        </div>
        <div class="item-list gear-list">
          {{#each gear}}
          <div class="item-row gear-row {{#unless system.equipped}}unequipped{{/unless}}"
               data-item-id="{{id}}">
            <div class="item-name">
              <span class="gear-dice-badge">{{system.gearDice}}d6</span>
              <span class="item-label">{{name}}</span>
              {{#if system.isDefensive}}
                <span class="defensive-badge" title="Defensive">🛡</span>
              {{/if}}
            </div>
            <div class="item-controls">
              <button type="button" class="item-equip-toggle" data-item-id="{{id}}"
                      title="{{#if system.equipped}}Unequip{{else}}Equip{{/if}}">
                {{#if system.equipped}}◉{{else}}◎{{/if}}
              </button>
              <button type="button" class="item-edit" data-item-id="{{id}}"
                      title="Edit">✎</button>
              <button type="button" class="item-delete" data-item-id="{{id}}"
                      title="Delete">✕</button>
            </div>
          </div>
          {{else}}
          <div class="item-row empty-row">
            <span class="empty-label">No gear</span>
          </div>
          {{/each}}
        </div>
      </div>{{!-- /.gear-section --}}

    </div>{{!-- /.talents-gear-row --}}

    {{!-- ── ABILITIES ────────────────────────────── --}}
    <div class="abilities-section">
      <div class="section-header">
        <span class="section-title">Abilities</span>
        <button type="button" class="item-create-btn"
                data-type="ability" title="Add Ability">+</button>
      </div>
      <div class="item-list abilities-list">
        {{#each abilities}}
        <div class="item-row ability-row" data-item-id="{{id}}">
          <div class="item-name">
            <span class="ability-level-badge" title="Level {{system.abilityLevel}} ability">
              L{{system.abilityLevel}}
            </span>
            <span class="item-label">{{name}}</span>
            {{#if system.prerequisite}}
              <span class="prereq-badge" title="Requires: {{system.prerequisite}}">
                Req: {{system.prerequisite}}
              </span>
            {{/if}}
            {{#if system.hasUses}}
              <span class="uses-pip">
                {{system.uses.current}}/{{system.uses.max}}
                <button type="button" class="use-ability-btn"
                        data-item-id="{{id}}" title="Use">▶</button>
              </span>
            {{/if}}
          </div>
          <div class="item-summary">{{#if system.diceBonus.amount}}+{{system.diceBonus.amount}}d6{{/if}}
            {{system.diceBonus.condition}}</div>
          <div class="item-controls">
            <button type="button" class="item-edit" data-item-id="{{id}}"
                    title="Edit">✎</button>
            <button type="button" class="item-delete" data-item-id="{{id}}"
                    title="Delete">✕</button>
          </div>
        </div>
        {{else}}
        <div class="item-row empty-row">
          <span class="empty-label">No abilities yet — drag from compendium or click +</span>
        </div>
        {{/each}}
      </div>
    </div>{{!-- /.abilities-section --}}

    {{!-- ── REPUTATION ───────────────────────────── --}}
    <div class="reputation-section">
      <div class="section-title">Reputation</div>
      <div class="reputation-track">
        {{#each reputationTiers}}
        <div class="rep-tier {{#if active}}active{{/if}} {{#if current}}current{{/if}}"
             data-tier="{{index}}" title="{{label}}">
          <span class="rep-label">{{label}}</span>
        </div>
        {{/each}}
      </div>
      <div class="reputation-counters">
        <label>Feats earned:
          <input type="number" name="system.reputation.featsEarned"
                 value="{{system.reputation.featsEarned}}" min="0" />
        </label>
        <span class="rep-threshold">
          / {{reputationThreshold.featsNeeded}} needed to advance
        </span>
        <label>Failures earned:
          <input type="number" name="system.reputation.failuresEarned"
                 value="{{system.reputation.failuresEarned}}" min="0" />
        </label>
        {{#if reputationThreshold.failuresNeeded}}
        <span class="rep-threshold">
          / {{reputationThreshold.failuresNeeded}} to drop
        </span>
        {{/if}}
      </div>
    </div>{{!-- /.reputation-section --}}

  </section>{{!-- /.tab play --}}

  {{!-- ═══════════════════════════════════════════ --}}
  {{!-- TAB: CONCEPT + MOVES (Page 2)              --}}
  {{!-- ═══════════════════════════════════════════ --}}
  <section class="tab-content {{#if (eq activeTab "concept")}}active{{/if}}"
           data-tab="concept">

    <div class="sidebar-accent"></div>

    <div class="concept-moves-layout">

      {{!-- LEFT: MOVES REFERENCE ─────────────────── --}}
      <div class="moves-column">
        <div class="section-title">Moves</div>
        <p class="moves-intro">Standard moves every character can perform.
          Unless stated otherwise, you can make one move per turn.</p>

        <div class="moves-grid">
          {{#each moves}}
          <div class="move-entry {{#if rollable}}rollable{{/if}}"
               data-stat="{{stat}}" data-move="{{key}}">
            <div class="move-name">{{name}}</div>
            <div class="move-desc">{{description}}</div>
            {{#if rollable}}
              <button type="button" class="move-roll-btn"
                      data-stat="{{stat}}" data-label="{{name}}"
                      title="Roll {{name}}">
                Roll ({{statLabel}})
              </button>
            {{/if}}
          </div>
          {{/each}}
        </div>
      </div>{{!-- /.moves-column --}}

      {{!-- RIGHT: CONCEPT ─────────────────────────── --}}
      <div class="concept-column">
        <div class="section-title">Concept</div>

        <div class="concept-field">
          <label class="field-label">Origin Story</label>
          <textarea name="system.origin" rows="4"
                    placeholder="How did your character discover their powers?">{{system.origin}}</textarea>
        </div>

        <div class="concept-field">
          <label class="field-label">Motive</label>
          <textarea name="system.motive" rows="4"
                    placeholder="What drives your paragon?">{{system.motive}}</textarea>
        </div>

        <div class="concept-field">
          <label class="field-label">Flaw</label>
          <textarea name="system.flaw" rows="4"
                    placeholder="What makes your character human?">{{system.flaw}}</textarea>
        </div>

        <div class="concept-field">
          <label class="field-label">Biography</label>
          {{editor system.biography target="system.biography"
                   button=true editable=editable}}
        </div>

      </div>{{!-- /.concept-column --}}

    </div>{{!-- /.concept-moves-layout --}}

  </section>{{!-- /.tab concept --}}

</form>
