{{!-- npc-main.hbs — Invincible-style NPC stat block --}}
<section class="tab {{tabs.main.cssClass}}" data-tab="main" data-group="primary">

<div class="main-sheet">

  {{!-- NPC HEADER --}}
  <header class="sheet-header npc-sheet-header">
    <div class="bg-accent"></div>

    <div class="header-portrait">
      <img class="profile-img clickable"
           src="{{actor.img}}"
           data-action="onEditImage"
           data-tooltip="Change portrait" />
    </div>

    <div class="header-fields">
      <div class="header-name-row">
        <div class="form-group name-wide">
          <label>NPC Name</label>
          <input type="text" name="name" value="{{actor.name}}" placeholder="Name" />
        </div>
        <div class="form-group">
          <label>Secret Identity</label>
          <input type="text" name="system.secretId" value="{{system.secretId}}" />
        </div>
        <div class="form-group">
          <label>Type</label>
          <select name="system.npcType">
            {{#each npcTypeChoices}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </div>
      </div>
    </div>

    {{!-- Power Rating block --}}
    <div class="power-rating-block">
      <div class="pr-label">Power Rating</div>
      <input type="number" name="system.powerRating" value="{{system.powerRating}}"
             min="0" max="7" class="pr-value" />
      <div class="pr-sublabel">{{powerRatingLabel}}</div>
      <div class="pr-guidelines">
        <span data-tooltip="Max dice pool"><i class="fas fa-dice-d6"></i> {{prGuidelines.dicePoolMax}}d6</span>
        <span data-tooltip="Max stat total"><i class="fas fa-chart-bar"></i> {{prGuidelines.maxStatTotal}}</span>
        <span data-tooltip="Max Will+Resist"><img src="systems/paragons/icons/heart.svg" width="14" height="14" /> {{prGuidelines.maxWillResistTotal}}</span>
      </div>
      <label class="checkbox-label human-toggle">
        <input type="checkbox" name="system.isHuman" {{#if system.isHuman}}checked{{/if}} />
        <span>Human (–1 effective PR)</span>
      </label>
    </div>
  </header>

  {{!-- STATS GRID --}}
  <label class="title attribute">Stats</label>
  <div class="grid grid-5col stats-grid">
    {{#each stats}}
    <div class="attribute {{key}}">
      <img class="stat-icon" src="systems/paragons/icons/{{key}}.svg" alt="{{label}}" />
      <input type="number" name="system.stats.{{key}}" value="{{value}}" min="0" max="20"
             data-dtype="Number" />
      <label class="attribute-label">{{label}}</label>
    </div>
    {{/each}}
  </div>

  <div class="stat-total-bar">
    <span>Stat Total: <strong>{{statTotal}}</strong> / {{prGuidelines.maxStatTotal}} cap</span>
    {{#if statOverCap}}<span class="over-cap"><i class="fas fa-triangle-exclamation"></i> Over cap</span>{{/if}}
  </div>

  {{!-- DERIVED --}}
  <div class="derived-row">
    <div class="bar">
      <img class="derived-icon" src="systems/paragons/icons/will.svg" alt="Will" />
      <label>Will</label>
      <div class="form-fields">
        <input type="number" name="system.will.value" value="{{system.will.value}}" min="0" data-dtype="Number" />
        <label>/</label>
        <input type="number" name="system.will.max"   value="{{system.will.max}}"   min="0" data-dtype="Number" class="max-editable" />
      </div>
    </div>
    <div class="bar">
      <img class="derived-icon" src="systems/paragons/icons/resist.svg" alt="Resist" />
      <label>Resist</label>
      <div class="form-fields">
        <input type="number" name="system.resist.value" value="{{system.resist.value}}" min="0" data-dtype="Number" />
        <label>/</label>
        <input type="number" name="system.resist.max"   value="{{system.resist.max}}"   min="0" data-dtype="Number" class="max-editable" />
      </div>
    </div>
    <div class="bar bar-total {{#if willResistOverCap}}over-cap{{/if}}">
      <label>W + R</label>
      <div class="form-fields">
        <span class="derived-total">{{willResistTotal}}</span>
        <label>/</label>
        <span>{{prGuidelines.maxWillResistTotal}}</span>
      </div>
    </div>
    <div class="bar bar-single">
      <img class="derived-icon" src="systems/paragons/icons/movement.svg" alt="Movement" />
      <label>Movement</label>
      <div class="form-fields">
        <input type="number" name="system.movement" value="{{system.movement}}" min="0" data-dtype="Number" />
      </div>
    </div>
    <div class="bar bar-single">
      <label>Pool Max</label>
      <div class="form-fields">
        <input type="number" name="system.dicePoolMax" value="{{system.dicePoolMax}}" min="1" data-dtype="Number" />
        <label>d6</label>
      </div>
    </div>
  </div>

  {{!-- ATTACK MOVES --}}
  <label class="title">
    <img class="section-icon" src="systems/paragons/icons/attack.svg" alt="" />
    Attack Moves
    <button type="button" class="item-create title-btn" data-action="addAttack">
      <i class="fas fa-plus"></i>
    </button>
  </label>
  <ul class="items-list attack-list">
    <li class="item flexrow items-header">
      <div class="item-name">Name</div>
      <div class="item-meta">Stat</div>
      <div class="item-meta">Pool</div>
      <div class="item-meta">Range</div>
      <div class="item-controls"></div>
    </li>
    {{#each system.attackMoves}}
    <li class="item attack-info flexrow" data-index="{{@index}}">
      <div class="item-name attack-name-input">
        <input type="text" name="system.attackMoves.{{@index}}.label"
               value="{{label}}" placeholder="Attack name" />
      </div>
      <div class="item-meta">
        <select name="system.attackMoves.{{@index}}.stat">
          {{#each ../statChoices}}
          <option value="{{value}}" {{#if (eq value ../stat)}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="item-meta attack-pool">
        <input type="number" name="system.attackMoves.{{@index}}.dicePool"
               value="{{dicePool}}" min="1" max="30" />
        <span>d6</span>
      </div>
      <div class="item-meta">
        <select name="system.attackMoves.{{@index}}.range">
          <option value="close"   {{#if (eq range "close")}}selected{{/if}}>Close</option>
          <option value="near"    {{#if (eq range "near")}}selected{{/if}}>Near</option>
          <option value="far"     {{#if (eq range "far")}}selected{{/if}}>Far</option>
          <option value="distant" {{#if (eq range "distant")}}selected{{/if}}>Distant</option>
        </select>
      </div>
      <div class="item-controls">
        <a class="item-control rollable" data-action="rollAttack" data-index="{{@index}}" data-tooltip="Roll">
          <i class="fas fa-dice-d6"></i>
        </a>
        <a class="item-control" data-action="deleteAttack" data-index="{{@index}}" data-tooltip="Remove">
          <i class="fas fa-trash"></i>
        </a>
      </div>
    </li>
    {{else}}
    <li class="item flexrow empty-row"><span class="empty-label">No attack moves — click + to add</span></li>
    {{/each}}
  </ul>

</div>
</section>
