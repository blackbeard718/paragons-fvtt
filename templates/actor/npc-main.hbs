{{!-- npc-main.hbs — stat block tab --}}
<section class="tab npc-main {{tabs.sheet.main.cssClass}}" data-tab="main" data-group="sheet">

  <div class="sidebar-accent"></div>

  <div class="npc-header">
    <div class="npc-header-left">
      <div class="field-group">
        <label class="field-label">NPC Name</label>
        <input type="text" name="name" value="{{actor.name}}" class="paragon-name-input" />
      </div>
      <div class="npc-header-meta">
        <div class="field-group">
          <label class="field-label">Secret Identity</label>
          <input type="text" name="system.secretId" value="{{system.secretId}}" />
        </div>
        <div class="field-group npc-type-group">
          <label class="field-label">Type</label>
          <select name="system.npcType">
            {{#each npcTypeChoices}}
            <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </div>
      </div>
    </div>
    <div class="power-rating-block">
      <div class="pr-label">Power Rating</div>
      <input type="number" name="system.powerRating" value="{{system.powerRating}}" min="0" max="7" class="pr-value" />
      <div class="pr-sublabel">{{powerRatingLabel}}</div>
      <div class="pr-guidelines">
        <span title="Max dice pool">🎲 {{prGuidelines.dicePoolMax}}d6</span>
        <span title="Max stat total">📊 {{prGuidelines.maxStatTotal}}</span>
        <span title="Max Will+Resist">❤️ {{prGuidelines.maxWillResistTotal}}</span>
      </div>
      <label class="checkbox-label human-toggle">
        <input type="checkbox" name="system.isHuman" {{#if system.isHuman}}checked{{/if}} />
        <span>Human (–1 effective PR)</span>
      </label>
    </div>
  </div>

  <div class="stats-row npc-stats-row">
    {{#each stats}}
    <div class="stat-block npc-stat-block">
      <div class="stat-label">{{label}}</div>
      <div class="stat-value-wrap">
        <input type="number" name="system.stats.{{key}}" value="{{value}}" min="0" max="20" class="stat-value" />
      </div>
      <div class="stat-icon" data-stat-icon="{{key}}"></div>
    </div>
    {{/each}}
  </div>

  <div class="stat-total-bar">
    <span>Stat Total: <strong>{{statTotal}}</strong> / {{prGuidelines.maxStatTotal}} cap</span>
    {{#if statOverCap}}<span class="over-cap">⚠ Over power rating cap</span>{{/if}}
  </div>

  <div class="derived-row npc-derived-row">
    <div class="derived-block will-block">
      <div class="derived-label">Will</div>
      <div class="derived-values">
        <input type="number" name="system.will.value" value="{{system.will.value}}" min="0" class="derived-current" />
        <span class="derived-sep">/</span>
        <input type="number" name="system.will.max"   value="{{system.will.max}}"   min="0" class="derived-max-input" />
      </div>
    </div>
    <div class="derived-block resist-block">
      <div class="derived-label">Resist</div>
      <div class="derived-values">
        <input type="number" name="system.resist.value" value="{{system.resist.value}}" min="0" class="derived-current" />
        <span class="derived-sep">/</span>
        <input type="number" name="system.resist.max"   value="{{system.resist.max}}"   min="0" class="derived-max-input" />
      </div>
    </div>
    <div class="derived-block">
      <div class="derived-label">Will + Resist</div>
      <div class="derived-values">
        <span class="derived-total {{#if willResistOverCap}}over-cap{{/if}}">{{willResistTotal}}</span>
        <span class="derived-sep">/</span>
        <span class="derived-cap">{{prGuidelines.maxWillResistTotal}}</span>
      </div>
    </div>
    <div class="derived-block movement-block">
      <div class="derived-label">Movement</div>
      <div class="derived-values">
        <input type="number" name="system.movement" value="{{system.movement}}" min="0" class="derived-current single" />
      </div>
    </div>
    <div class="derived-block">
      <div class="derived-label">Dice Pool Max</div>
      <div class="derived-values">
        <input type="number" name="system.dicePoolMax" value="{{system.dicePoolMax}}" min="1" class="derived-current single" />
      </div>
    </div>
  </div>

  <div class="attack-moves-section">
    <div class="section-header">
      <span class="section-title">Attack Moves</span>
      <button type="button" data-action="addAttack" class="item-create-btn">+</button>
    </div>
    <div class="attack-moves-list">
      {{#each system.attackMoves}}
      <div class="attack-row" data-index="{{@index}}">
        <div class="attack-name">
          <input type="text" name="system.attackMoves.{{@index}}.label" value="{{label}}" placeholder="Attack name" />
        </div>
        <div class="attack-stat">
          <select name="system.attackMoves.{{@index}}.stat">
            {{#each ../statChoices}}
            <option value="{{value}}" {{#if (eq value ../stat)}}selected{{/if}}>{{label}}</option>
            {{/each}}
          </select>
        </div>
        <div class="attack-pool">
          <label class="field-label">Pool</label>
          <input type="number" name="system.attackMoves.{{@index}}.dicePool" value="{{dicePool}}" min="1" max="30" />
          <span class="pool-label">d6</span>
        </div>
        <div class="attack-range">
          <select name="system.attackMoves.{{@index}}.range">
            <option value="close"   {{#if (eq range "close")}}selected{{/if}}>Close</option>
            <option value="near"    {{#if (eq range "near")}}selected{{/if}}>Near</option>
            <option value="far"     {{#if (eq range "far")}}selected{{/if}}>Far</option>
            <option value="distant" {{#if (eq range "distant")}}selected{{/if}}>Distant</option>
          </select>
        </div>
        <div class="attack-controls">
          <button type="button" data-action="rollAttack"   data-index="{{@index}}" class="roll-attack-btn" title="Roll">🎲</button>
          <button type="button" data-action="deleteAttack" data-index="{{@index}}" class="delete-attack-btn" title="Remove">✕</button>
        </div>
      </div>
      {{else}}
      <div class="empty-row"><span class="empty-label">No attack moves — click + to add</span></div>
      {{/each}}
    </div>
  </div>

</section>
