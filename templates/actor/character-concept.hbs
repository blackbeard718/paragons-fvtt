{{!-- character-concept.hbs — concept & moves tab (page 2) --}}
<section class="tab {{tabs.concept.cssClass}}" data-tab="concept" data-group="primary">

  <div class="sidebar-accent"></div>

  <div class="concept-moves-layout">

    {{!-- MOVES --}}
    <div class="moves-column">
      <div class="section-title">Moves</div>
      <p class="moves-intro">Standard moves every character can perform. Unless stated otherwise, you can make one move per turn.</p>
      <div class="moves-grid">
        {{#each moves}}
        <div class="move-entry {{#if rollable}}rollable{{/if}}">
          <div class="move-name">{{name}}</div>
          <div class="move-desc">{{description}}</div>
          {{#if rollable}}
          <button type="button" class="move-roll-btn"
                  data-action="rollMove"
                  data-stat="{{stat}}"
                  data-label="{{name}}">
            Roll ({{statLabel}})
          </button>
          {{/if}}
        </div>
        {{/each}}
      </div>
    </div>

    {{!-- CONCEPT --}}
    <div class="concept-column">
      <div class="section-title">Concept</div>
      <div class="concept-field">
        <label class="field-label">Origin Story</label>
        <textarea name="system.origin" rows="4" placeholder="How did your character discover their powers?">{{system.origin}}</textarea>
      </div>
      <div class="concept-field">
        <label class="field-label">Motive</label>
        <textarea name="system.motive" rows="4" placeholder="What drives your paragon?">{{system.motive}}</textarea>
      </div>
      <div class="concept-field">
        <label class="field-label">Flaw</label>
        <textarea name="system.flaw" rows="4" placeholder="What makes your character human?">{{system.flaw}}</textarea>
      </div>
      <div class="concept-field">
        <label class="field-label">Biography</label>
        <textarea name="system.biography" rows="6" placeholder="Character history...">{{system.biography}}</textarea>
      </div>
    </div>

  </div>

</section>
