{{!-- npc-abilities.hbs --}}
<section class="tab npc-abilities {{tabs.sheet.abilities.cssClass}}" data-tab="abilities" data-group="sheet">
  <div class="sidebar-accent"></div>

  <div class="abilities-section">
    <div class="section-header">
      <span class="section-title">Abilities</span>
      <button type="button" data-action="itemCreate" data-type="ability" class="item-create-btn">+</button>
    </div>
    <div class="item-list abilities-list">
      {{#each abilities}}
      <div class="item-row ability-row" data-item-id="{{id}}">
        <div class="item-name">
          <span class="ability-level-badge">L{{system.abilityLevel}}</span>
          <span class="item-label">{{name}}</span>
          {{#if system.diceBonus.amount}}<span class="item-summary">+{{system.diceBonus.amount}}d6</span>{{/if}}
        </div>
        <div class="item-controls">
          <button type="button" data-action="itemEdit"   data-item-id="{{id}}">✎</button>
          <button type="button" data-action="itemDelete" data-item-id="{{id}}">✕</button>
        </div>
      </div>
      {{else}}
      <div class="item-row empty-row"><span class="empty-label">No abilities</span></div>
      {{/each}}
    </div>
  </div>

  <div class="gear-section" style="margin-top:14px;">
    <div class="section-header">
      <span class="section-title">Gear</span>
      <button type="button" data-action="itemCreate" data-type="gear" class="item-create-btn">+</button>
    </div>
    <div class="item-list gear-list">
      {{#each gear}}
      <div class="item-row gear-row" data-item-id="{{id}}">
        <div class="item-name">
          <span class="gear-dice-badge">{{system.gearDice}}d6</span>
          <span class="item-label">{{name}}</span>
          {{#if system.isDefensive}}<span class="defensive-badge">🛡</span>{{/if}}
        </div>
        <div class="item-controls">
          <button type="button" data-action="itemEdit"   data-item-id="{{id}}">✎</button>
          <button type="button" data-action="itemDelete" data-item-id="{{id}}">✕</button>
        </div>
      </div>
      {{else}}
      <div class="item-row empty-row"><span class="empty-label">No gear</span></div>
      {{/each}}
    </div>
  </div>

  <div class="stat-total-bar" style="margin-top:10px;">
    <span>Ability + Gear total: <strong>{{abilityGearTotal}}</strong> / {{prGuidelines.abilityGearTotal}} cap</span>
  </div>
</section>
