{{!-- character-tabs.hbs — V13 tab nav using primary group --}}
<nav class="sheet-tabs tabs" data-group="primary" aria-roledescription="tabs">
  {{#each tabs.primary as |tab|}}
  <a class="item {{tab.cssClass}}"
     data-action="tab"
     data-tab="{{tab.id}}"
     data-group="primary">
    {{tab.label}}
  </a>
  {{/each}}
</nav>
