{{!-- templates/chat/roll-card.hbs --}}
{{!-- Paragons dice pool result card --}}

<div class="paragons-roll-card {{#if isFailure}}failure{{else}}success{{/if}}"
     data-actor-id="{{actorId}}">

  {{!-- Header --}}
  <div class="roll-card-header">
    <span class="roll-card-label">{{label}}</span>
    {{#if flavor}}
      <p class="roll-card-flavor">{{flavor}}</p>
    {{/if}}
    {{#if isDeathRoll}}
      <span class="roll-tag death-roll">Death Roll</span>
    {{/if}}
    {{#if (eq rollType "attack")}}
      <span class="roll-tag attack-roll">Attack</span>
    {{/if}}
    {{#if (eq rollType "resist")}}
      <span class="roll-tag resist-roll">Resist</span>
    {{/if}}
  </div>

  {{!-- Die Results --}}
  <div class="roll-card-dice">
    {{#each results}}
      <div class="die-result {{#if isCritical}}critical{{else if isSuccess}}success{{else}}failure{{/if}}"
           title="{{#if isCritical}}Critical — 2 successes{{else if isSuccess}}Success{{else}}Failure{{/if}}">
        <span class="die-face">{{value}}</span>
        {{#if isCritical}}
          <span class="die-badge">★★</span>
        {{else if isSuccess}}
          <span class="die-badge">★</span>
        {{/if}}
      </div>
    {{/each}}
  </div>

  {{!-- Pool Breakdown --}}
  <div class="roll-card-breakdown">
    <span class="breakdown-label">Pool:</span>
    <span class="breakdown-detail">{{breakdown}}</span>
  </div>

  {{!-- Result --}}
  <div class="roll-card-result {{#if isFailure}}result-failure{{else}}result-success{{/if}}">
    {{#if isFailure}}
      <i class="fas fa-times-circle"></i>
      <span>Failure</span>
    {{else}}
      <i class="fas fa-check-circle"></i>
      <span>{{successLabel}}</span>
    {{/if}}
    {{#if coolPointSpent}}
      <span class="cp-spent-badge" title="Cool Point spent for +1 success">
        <i class="fas fa-star"></i> CP
      </span>
    {{/if}}
  </div>

  {{!-- Attack damage hint --}}
  {{#if (eq rollType "attack")}}
    {{#if isSuccess}}
      <div class="roll-card-damage-hint">
        Deals <strong>{{totalSuccesses}}</strong>
        {{#if (eq totalSuccesses 1)}}damage{{else}}damage{{/if}}
        — target may spend Resist to mitigate.
      </div>
    {{/if}}
  {{/if}}

  {{!-- Cool Point spend button --}}
  {{#if canSpendCP}}
    <div class="roll-card-actions">
      <button class="paragons-spend-cp" type="button">
        <i class="fas fa-star"></i>
        Spend Cool Point (+1 success)
        <span class="cp-hint">GM gains 1 Story Point</span>
      </button>
    </div>
  {{/if}}

  {{!-- Already spent notice --}}
  {{#if coolPointSpent}}
    <div class="roll-card-actions">
      <p class="cp-spent-notice">
        <i class="fas fa-star"></i> Cool Point spent — +1 success applied.
      </p>
    </div>
  {{/if}}

</div>
