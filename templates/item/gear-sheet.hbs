{{!-- gear-sheet.hbs — Invincible-style, V13 --}}
<div class="paragons-sheet item-sheet gear-sheet">

  <div class="item-sheet-header">
    <div class="bg-accent"></div>
    <img class="item-sheet-img clickable" src="{{item.img}}" title="{{item.name}}"
         data-action="editImage" data-field="img" />
    <div class="item-sheet-title">
      <input type="text" name="name" value="{{item.name}}" class="item-name-input" placeholder="Gear Name" />
      <div class="item-sheet-meta">
        <span class="item-type-badge">Gear</span>
        <select name="system.gearDice" class="inline-select">
          <option value="1" {{#if (eq system.gearDice 1)}}selected{{/if}}>1d6 — Improvised</option>
          <option value="2" {{#if (eq system.gearDice 2)}}selected{{/if}}>2d6 — Right Tool</option>
          <option value="3" {{#if (eq system.gearDice 3)}}selected{{/if}}>3d6 — Specialized</option>
        </select>
        <select name="system.range" class="inline-select">
          <option value="">N/A</option>
          <option value="close"   {{#if (eq system.range "close")}}selected{{/if}}>Close</option>
          <option value="near"    {{#if (eq system.range "near")}}selected{{/if}}>Near</option>
          <option value="far"     {{#if (eq system.range "far")}}selected{{/if}}>Far</option>
          <option value="distant" {{#if (eq system.range "distant")}}selected{{/if}}>Distant</option>
        </select>
      </div>
    </div>
  </div>

  <div class="item-body">

    <div class="gear-flags-row">
      <label class="checkbox-label"><input type="checkbox" name="system.isDefensive" {{#if system.isDefensive}}checked{{/if}} /> Defensive</label>
      <label class="checkbox-label"><input type="checkbox" name="system.isArtifact"  {{#if system.isArtifact}}checked{{/if}} /> Artifact</label>
      <label class="checkbox-label"><input type="checkbox" name="system.equipped"    {{#if system.equipped}}checked{{/if}} /> Equipped</label>
    </div>

    <label class="title">Description</label>
    <div class="form-group">
      <textarea name="system.description" rows="5" placeholder="What this gear does...">{{system.description}}</textarea>
    </div>
    <div class="form-group">
      <label class="field-label">Prerequisite</label>
      <input type="text" name="system.prerequisite" value="{{system.prerequisite}}"
             placeholder="e.g. Telepathy ability required" />
    </div>

    <label class="title">Stat Modifications <span class="field-hint">(Unique Gear)</span></label>
    <div class="form-row stat-mods-row">
      {{#each statModFields}}
      <div class="form-group narrow">
        <label class="field-label">{{label}}</label>
        <input type="number" name="system.statMods.{{key}}" value="{{value}}" />
      </div>
      {{/each}}
    </div>

    <label class="title">Additional Dice Bonus</label>
    <div class="form-row">
      <div class="form-group narrow">
        <label class="field-label">Bonus Dice (d6)</label>
        <input type="number" name="system.diceBonus.amount" value="{{system.diceBonus.amount}}" min="0" max="6" />
      </div>
      <div class="form-group wide">
        <label class="field-label">Condition</label>
        <input type="text" name="system.diceBonus.condition" value="{{system.diceBonus.condition}}"
               placeholder="e.g. +2d6 when using Telepathy" />
      </div>
    </div>

    <label class="title">Granted Ability</label>
    <div class="form-group">
      <label class="field-label">Grants Ability (name)</label>
      <input type="text" name="system.grantsAbility" value="{{system.grantsAbility}}"
             placeholder="e.g. Speedster (Marathon Boots)" />
    </div>

  </div>
</div>
