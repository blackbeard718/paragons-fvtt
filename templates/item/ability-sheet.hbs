{{!-- ability-sheet.hbs — Paragons Ability, V13 --}}
<div class="paragons-sheet item-sheet ability-sheet">

  {{!-- Header --}}
  <div class="item-sheet-header">
    <div class="bg-accent"></div>
    <img class="item-sheet-img clickable" src="{{item.img}}" title="{{item.name}}"
         data-action="editImage" data-field="img" />
    <div class="item-sheet-title">
      <input type="text" name="name" value="{{item.name}}" class="item-name-input" placeholder="Ability Name" />
      <div class="item-sheet-meta">
        <span class="item-type-badge">Ability</span>
        <select name="system.abilityLevel" class="inline-select">
          <option value="1" {{#if (eq system.abilityLevel 1)}}selected{{/if}}>Level 1</option>
          <option value="3" {{#if (eq system.abilityLevel 3)}}selected{{/if}}>Level 3</option>
          <option value="6" {{#if (eq system.abilityLevel 6)}}selected{{/if}}>Level 6</option>
        </select>
        <label class="checkbox-inline">
          <input type="checkbox" name="system.repeatable" {{#if system.repeatable}}checked{{/if}} />
          Repeatable
        </label>
      </div>
    </div>
  </div>

  <div class="item-body">

    <label class="title">Description</label>
    <div class="form-group">
      <textarea name="system.description" rows="4" placeholder="What this ability does...">{{system.description}}</textarea>
    </div>
    {{#if system.outsideAction}}
    <div class="form-group">
      <label class="field-label">Outside the Action</label>
      <textarea name="system.outsideAction" rows="2">{{system.outsideAction}}</textarea>
    </div>
    {{else}}
    <div class="form-group">
      <label class="field-label">Outside the Action</label>
      <textarea name="system.outsideAction" rows="2" placeholder="Effects outside combat..."></textarea>
    </div>
    {{/if}}

    <div class="form-group">
      <label class="field-label">Prerequisite</label>
      <input type="text" name="system.prerequisite" value="{{system.prerequisite}}" placeholder="None" />
    </div>

    <label class="title">Dice Bonus</label>
    <div class="form-row">
      <div class="form-group narrow">
        <label class="field-label">Amount (d6)</label>
        <input type="number" name="system.diceBonus.amount" value="{{system.diceBonus.amount}}" min="0" max="10" />
      </div>
      <div class="form-group">
        <label class="field-label">Roll Type</label>
        <select name="system.diceBonus.rollType">
          <option value="none"       {{#if (eq system.diceBonus.rollType "none")}}selected{{/if}}>None</option>
          <option value="any"        {{#if (eq system.diceBonus.rollType "any")}}selected{{/if}}>Any roll</option>
          <option value="attack"     {{#if (eq system.diceBonus.rollType "attack")}}selected{{/if}}>Any attack</option>
          <option value="melee"      {{#if (eq system.diceBonus.rollType "melee")}}selected{{/if}}>Melee attack</option>
          <option value="ranged"     {{#if (eq system.diceBonus.rollType "ranged")}}selected{{/if}}>Ranged attack</option>
          <option value="hide"       {{#if (eq system.diceBonus.rollType "hide")}}selected{{/if}}>Hide</option>
          <option value="manipulate" {{#if (eq system.diceBonus.rollType "manipulate")}}selected{{/if}}>Manipulate</option>
          <option value="observe"    {{#if (eq system.diceBonus.rollType "observe")}}selected{{/if}}>Observe</option>
          <option value="specific"   {{#if (eq system.diceBonus.rollType "specific")}}selected{{/if}}>Specific</option>
        </select>
      </div>
      <div class="form-group wide">
        <label class="field-label">Condition</label>
        <input type="text" name="system.diceBonus.condition" value="{{system.diceBonus.condition}}"
               placeholder="e.g. when making a Finesse melee attack" />
      </div>
    </div>

    <label class="title">Stat Modifications</label>
    <div class="form-row stat-mods-row">
      {{#each statModFields}}
      <div class="form-group narrow">
        <label class="field-label">{{label}}</label>
        <input type="number" name="system.statMods.{{key}}" value="{{value}}" />
      </div>
      {{/each}}
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="field-label">Physique Mult</label>
        <input type="number" name="system.statMods.physiqueMult" value="{{system.statMods.physiqueMult}}" min="1" max="4" />
      </div>
      <div class="form-group">
        <label class="field-label">Acuity Mult</label>
        <input type="number" name="system.statMods.acuityMult" value="{{system.statMods.acuityMult}}" min="1" max="4" />
      </div>
      <div class="form-group">
        <label class="field-label">Will Bonus</label>
        <input type="number" name="system.statMods.willBonus" value="{{system.statMods.willBonus}}" min="0" />
      </div>
    </div>

    <label class="title">Movement &amp; Special</label>
    <div class="form-row">
      <div class="form-group">
        <label class="field-label">Movement Override <span class="field-hint">(0 = none)</span></label>
        <input type="number" name="system.movementOverride" value="{{system.movementOverride}}" min="0" />
      </div>
      <div class="form-group">
        <label class="field-label">Auto-successes on Hide</label>
        <input type="number" name="system.flags.autoSuccessOnHide" value="{{system.flags.autoSuccessOnHide}}" min="0" max="3" />
      </div>
      <div class="form-group">
        <label class="field-label">Seer uses/episode</label>
        <input type="number" name="system.flags.seerUsesPerEpisode" value="{{system.flags.seerUsesPerEpisode}}" min="0" />
      </div>
    </div>
    <div class="form-row checkboxes-row">
      <label class="checkbox-label"><input type="checkbox" name="system.flags.grantsFly"          {{#if system.flags.grantsFly}}checked{{/if}} /> Grants Fly</label>
      <label class="checkbox-label"><input type="checkbox" name="system.flags.grantsTelepathy"    {{#if system.flags.grantsTelepathy}}checked{{/if}} /> Grants Telepathy</label>
      <label class="checkbox-label"><input type="checkbox" name="system.flags.grantsTelekinesis"  {{#if system.flags.grantsTelekinesis}}checked{{/if}} /> Grants Telekinesis</label>
      <label class="checkbox-label"><input type="checkbox" name="system.flags.grantsExtraAbility" {{#if system.flags.grantsExtraAbility}}checked{{/if}} /> Grants Extra Ability</label>
      <label class="checkbox-label"><input type="checkbox" name="system.flags.deathPrevention"    {{#if system.flags.deathPrevention}}checked{{/if}} /> Death Prevention</label>
    </div>

    <label class="title">Uses / Frequency</label>
    <div class="form-row">
      <div class="form-group">
        <label class="field-label">Resets Per</label>
        <select name="system.uses.per">
          <option value="unlimited" {{#if (eq system.uses.per "unlimited")}}selected{{/if}}>Unlimited</option>
          <option value="episode"   {{#if (eq system.uses.per "episode")}}selected{{/if}}>Episode</option>
          <option value="scene"     {{#if (eq system.uses.per "scene")}}selected{{/if}}>Scene</option>
          <option value="turn"      {{#if (eq system.uses.per "turn")}}selected{{/if}}>Turn</option>
        </select>
      </div>
      <div class="form-group narrow">
        <label class="field-label">Max</label>
        <input type="number" name="system.uses.max" value="{{system.uses.max}}" min="0" />
      </div>
      <div class="form-group narrow">
        <label class="field-label">Current</label>
        <input type="number" name="system.uses.current" value="{{system.uses.current}}" min="0" />
      </div>
    </div>

  </div>
</div>
