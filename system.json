{
  "id": "paragons",
  "title": "Paragons: The Roleplaying Game",
  "description": "An Unofficial implementation of Paragons: The Roleplaying Game by Broken Door Entertainment.",
  "version": "0.2.5",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "authors": [
    {
      "name": "blackbeard718"
    }
  ],
  "url": "https://github.com/blackbeard718/paragons-fvtt",
  "readme": "README.md",
  "bugs": "https://github.com/blackbeard718/paragons-fvtt/issues",
  "changelog": "https://github.com/blackbeard718/paragons-fvtt/releases",
  "media": [
    {
      "type": "setup",
      "url": "assets/paragons.png",
      "thumbnail": "assets/paragons.png"
    }
  "esmodules": [
    "module/paragons.mjs"
  ],
  "styles": [
    "css/paragons.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "documentTypes": {
    "Actor": {
      "character": {
        "htmlFields": [
          "biography",
          "notes"
        ],
        "filePathFields": {
          "portrait": [
            "https://www.onlycrits.com/cdn/shop/articles/Fighting_for_the_Future_by_Dakota_Curry_1920.png?v=1727277108&width=1100"
          ]
        }
      },
      "npc": {
        "htmlFields": [
          "description"
        ]
      }
    },
    "Item": {
      "ability": {
        "htmlFields": [
          "description",
          "outsideAction"
        ]
      },
      "talent": {
        "htmlFields": [
          "description"
        ]
      },
      "gear": {
        "htmlFields": [
          "description"
        ]
      }
    }
  },
  "packs": [
    {
      "name": "abilities",
      "label": "Paragons Abilities",
      "path": "packs/abilities.db",
      "type": "Item",
      "system": "paragons"
    },
    {
      "name": "talents",
      "label": "Archetype Talents",
      "path": "packs/talents.db",
      "type": "Item",
      "system": "paragons"
    },
    {
      "name": "gear",
      "label": "Unique Gear",
      "path": "packs/gear.db",
      "type": "Item",
      "system": "paragons"
    },
    {
      "name": "npcs",
      "label": "NPCs",
      "path": "packs/npcs.db",
      "type": "Actor",
      "system": "paragons"
    }
  ],
  "url": "https://github.com/blackbeard718/paragons-fvtt",
  "manifest": "https://raw.githubusercontent.com/blackbeard718/paragons-fvtt/main/system.json",
  "download": "https://github.com/blackbeard718/paragons-fvtt/archive/refs/heads/main.zip"
}
