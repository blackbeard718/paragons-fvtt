{
  "name": "AEGIS-01 \"Titan\" (Nadia Kael)",
  "type": "npc",
  "img": "icons/svg/mystery-man.svg",
  "system": {
    "description": "<p>The architect of the Forgeborn. Nadia Kael spent fifteen years designing the AEGIS suit system before her family ever wore one. Her own suit — AEGIS-01 — is the oldest and most refined, rebuilt from scratch four times as her understanding evolved. In the field she does not fight from the front. She coordinates, anticipates, and controls the shape of every engagement. Opponents who focus on the loud members of the Forgeborn quickly learn that Titan is the one who beats them.</p>",
    "secretId": "Nadia Kael",
    "npcType": "hero",
    "powerRating": 4,
    "stats": {
      "physique": 3,
      "finesse": 4,
      "stamina": 4,
      "acuity": 8,
      "presence": 7
    },
    "will": {
      "value": 20,
      "max": 20
    },
    "resist": {
      "value": 12,
      "max": 12
    },
    "dicePoolMax": 15,
    "movement": 8,
    "traits": {
      "agenda": "Keep her family alive and finish every mission without a single loss.",
      "motive": "Family",
      "flaw": "Struggles to delegate — she trusts her own read of a situation over everyone else's, including her husband's."
    },
    "attackMoves": [
      {
        "label": "Tactical Override",
        "stat": "acuity",
        "dicePool": 10,
        "range": "far",
        "description": "Nadia seizes control of nearby electronics, drones, or enemy tech. On 3+ successes she can redirect one automated system per round."
      },
      {
        "label": "AEGIS Countermeasure",
        "stat": "acuity",
        "dicePool": 9,
        "range": "near",
        "description": "Deploys an EMP burst from AEGIS-01. All tech-dependent enemies Near lose 1 move next turn. Friendly AEGIS units are shielded."
      },
      {
        "label": "Precision Strike",
        "stat": "finesse",
        "dicePool": 7,
        "range": "near",
        "description": "Targeted melee hit to a joint or sensor array. On 2+ successes, reduces target's dice pool by 2d6 until end of their next turn."
      }
    ],
    "isHuman": true
  },
