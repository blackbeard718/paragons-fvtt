{
  "name": "Patchwork",
  "type": "npc",
  "img": "icons/svg/mystery-man.svg",
  "system": {
    "description": "<p>A street-level villain and small-time information broker who steals and resells paragon tech. Patchwork has no powers of his own but has cobbled together a patchwork suit of stolen, salvaged, and counterfeit components — hence the name. None of it works reliably. All of it is dangerous. He is genuinely funny, catastrophically unlucky, and a useful source of street-level intelligence for heroes willing to cut a deal instead of an arrest.</p>",
    "secretId": "Gil Marsh",
    "npcType": "antagonist",
    "powerRating": 1,
    "stats": {
      "physique": 2,
      "finesse": 5,
      "stamina": 2,
      "acuity": 5,
      "presence": 4
    },
    "will": {
      "value": 7,
      "max": 7
    },
    "resist": {
      "value": 5,
      "max": 5
    },
    "dicePoolMax": 8,
    "movement": 8,
    "traits": {
      "agenda": "Acquire, resell, survive. Ideally in that order.",
      "motive": "Greed",
      "flaw": "His stolen tech malfunctions at the worst possible moments — GM should roll 1d6 on any tech-based action; on a 1, it backfires."
    },
    "attackMoves": [
      {
        "label": "Stolen Blaster",
        "stat": "finesse",
        "dicePool": 5,
        "range": "far",
        "description": "Counterfeit energy weapon. On a dice roll of all 1s and 2s, it explodes harmlessly and Patchwork loses his next move."
      },
      {
        "label": "Smoke Vent",
        "stat": "acuity",
        "dicePool": 4,
        "range": "near",
        "description": "Releases a smoke cloud from a salvaged canister. All enemies Near have a 1d6 Circumstance penalty until the cloud disperses."
      },
      {
        "label": "Run",
        "stat": "finesse",
        "dicePool": 6,
        "range": "near",
        "description": "Patchwork's most reliable ability. He is fast when terrified."
      }
    ],
    "isHuman": true
  },
